MONGO_URI=mongodb+srv://username:password@cluster0.m65dh.mongodb.net/loan-tracker?appName=Cluster0
PORT=8000
NODE_ENV=development

# JWT
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_ACCESS_EXPIRES=1d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_REFRESH_EXPIRES=10d

# BCRYPT
BCRYPT_SALT_ROUND=10

# Frontend URL
FRONTEND_URL=http://localhost:5173

# SMTP
# SMTP USER is the email used to create the app
# SMTP_FROM is the email we will use to send emails

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_FROM=your_email@gmail.com
SMTP_PASS=your_app_password_here