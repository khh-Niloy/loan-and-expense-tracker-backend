<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Password Reset - Loan & Expense Tracker</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        font-family: "Segoe UI", Arial, sans-serif;
        background-color: #f4f6f8;
        color: #333333;
      }
      .container {
        max-width: 600px;
        margin: 40px auto;
        background: #ffffff;
        padding: 40px 30px;
        border-radius: 12px;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
      }
      h2 {
        color: #1e293b;
        font-size: 22px;
        margin-bottom: 16px;
        text-align: center;
      }
      p {
        line-height: 1.6;
        margin: 10px 0;
      }
      .btn {
        display: inline-block;
        padding: 14px 28px;
        margin: 25px 0;
        background: #16a34a;
        color: #ffffff !important;
        text-decoration: none;
        font-weight: 600;
        border-radius: 6px;
        transition: background 0.3s ease;
      }
      .btn:hover {
        background: #15803d;
      }
      .note {
        font-size: 14px;
        color: #555555;
        margin-top: 20px;
        background: #f9fafb;
        padding: 12px;
        border-radius: 6px;
        border: 1px solid #e5e7eb;
      }
      .footer {
        margin-top: 40px;
        text-align: center;
        font-size: 12px;
        color: #888888;
        border-top: 1px solid #eeeeee;
        padding-top: 20px;
      }
      .logo {
        text-align: center;
        margin-bottom: 20px;
      }
      .logo span {
        font-size: 20px;
        font-weight: bold;
        color: #16a34a;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="logo">
        💰 <span>Loan & Expense Tracker</span>
      </div>

      <h2>Password Reset Request</h2>
      <p>Hi <%= name %>,</p>
      <p>
        We received a request to reset the password for your Loan & Expense
        Tracker account. To continue, click the button below:
      </p>

      <a class="btn" href="<%= resetUILink %>">Reset My Password</a>

      <p class="note">
        ⚠️ If you did not request this password reset, you can safely ignore
        this email. For security, this link will expire in 10 minutes.
      </p>

      <div class="footer">
        &copy; <%= new Date().getFullYear() %> Loan & Expense Tracker. All rights reserved.
      </div>
    </div>
  </body>
</html>
